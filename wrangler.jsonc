{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "labmaes-site",
  "compatibility_date": "2026-05-25",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./_site"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
