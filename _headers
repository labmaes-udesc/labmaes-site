/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com

# HTML: nunca cachear no edge — sempre serve versão atual do deploy
/*.html
  Cache-Control: no-cache

# CSS e JS: sem fingerprint nas URLs → revalidar sempre
/css/*
  Cache-Control: no-cache

/js/*
  Cache-Control: no-cache

# Imagens e banners: podem ser substituídos entre deploys → 1 dia
/assets/images/*
  Cache-Control: public, max-age=86400

/assets/banners/*
  Cache-Control: public, max-age=86400

# Fontes: verdadeiramente imutáveis (nome do arquivo não muda) → 1 ano
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# SVGs de gráficos decorativos: podem mudar entre deploys → 1 dia
/assets/graphics/*
  Cache-Control: public, max-age=86400
